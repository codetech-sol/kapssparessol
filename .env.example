# =============================================================================
# KAPS Auto Spares — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in your real values:
#   cp .env.example .env
#
# Never commit `.env` — it is gitignored. This example file is safe to commit.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Server-side (SSR, API routes, admin operations)
# Get these from: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------

# Your project reference ID (the subdomain in your Supabase URL)
SUPABASE_PROJECT_ID="your-project-ref"

# Project URL — use the base URL only (do NOT add /rest/v1/)
SUPABASE_URL="https://your-project-ref.supabase.co"

# Publishable (anon) key — safe for client use when prefixed with VITE_
SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_key_here"

# Service role (secret) key — server-only, bypasses RLS. NEVER expose to browser.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_your_service_role_key_here"

# -----------------------------------------------------------------------------
# Supabase — Client-side (browser)
# Vite only exposes variables prefixed with VITE_ to the frontend bundle.
# Values should match the server-side Supabase entries above.
# -----------------------------------------------------------------------------

VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_key_here"

# -----------------------------------------------------------------------------
# SMTP — Chat lead notifications (/api/chat)
# Used by Nodemailer to forward chat form submissions to the admin inbox.
# Server-only — do NOT prefix with VITE_
# -----------------------------------------------------------------------------

SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"

# Inbox that receives new chat lead emails
ADMIN_EMAIL="admin@example.com"
